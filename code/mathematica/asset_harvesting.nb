Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"solve", " ", "the", " ", "expression"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"wSol", " ", "=", " ", 
     RowBox[{"Solve", "[", 
      RowBox[{"focInW", ",", " ", "w"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wExpr", " ", "=", " ", 
     RowBox[{"w", "/.", " ", 
      RowBox[{"wSol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", "wExpr"}]}]], "Input",
