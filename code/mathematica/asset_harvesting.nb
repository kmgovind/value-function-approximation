 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "u"}], " ", "\[Alpha]"}]], " ", "x", " ", "\[Alpha]"}], "-", 
   RowBox[{
    SuperscriptBox["V", "\[Prime]",
     MultilineFunction->None], "[", "x", "]"}]}], "\[Equal]", "0"}]], "Output",
