Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Take", " ", "the", " ", "log", " ", "by", " ", "hand"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"uSolExpr", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"1", "/", "\[Alpha]"}], ")"}]}], "*", 
      RowBox[{"Log", "[", "wExpr", "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"optimalU", "=", 
     RowBox[{"{", 
      RowBox[{"u", "->", 
       RowBox[{"Simplify", "[", 
        RowBox[{"uSolExpr", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"x", ">", "0"}], ",", 
           RowBox[{"\[Alpha]", ">", "0"}], ",", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"V", "[", "x", "]"}], ",", "x"}], "]"}], ">", "0"}]}], 
          "}"}]}], "]"}]}], "}"}]}], ";"}], "\n", "optimalU"}]}]], "Input",
