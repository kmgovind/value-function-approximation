Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "drift", " ", "and", " ", "diffusion", " ", 
    "coefficients"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"drift", "=", 
     RowBox[{
      RowBox[{"r", "*", "x"}], "-", "u"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"diffusion", "=", 
     RowBox[{"\[Sigma]", "*", "x"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "the", " ", "instantaneous", " ", 
     RowBox[{"utility", "/", "reward"}], " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"f", "=", 
     RowBox[{"x", "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "\[Alpha]"}], "*", "u"}], "]"}]}], ")"}]}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Construct", " ", "the", " ", "HJB", " ", "expression", " ", "inside", " ",
      "the", " ", "maximization", " ", "brackets"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"hjbExpression", "=", 
     RowBox[{"f", "+", 
      RowBox[{"drift", "*", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"V", "[", "x", "]"}], ",", "x"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"diffusion", "^", "2"}], ")"}], "*", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"V", "[", "x", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Display", " ", "the", " ", "full", " ", "HJB", " ", "equation", " ", 
     "before", " ", "maximization"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"hjbEq", "=", 
     RowBox[{
      RowBox[{"\[Rho]", "*", 
       RowBox[{"V", "[", "x", "]"}]}], "==", "hjbExpression"}]}], ";"}], "\n",
    "hjbEq"}]}]], "Input",
 CellChangeTimes->{{3.9907763204636307`*^9, 3.990776331451521*^9}, {
  3.990776429117056*^9, 3.9907764324143333`*^9}, {3.990776975517172*^9, 
  3.9907770066547375`*^9}, {3.9907770917210407`*^9, 3.9907770962364063`*^9}},
 CellLabel->"In[94]:=",ExpressionUUID->"463a91b0-5efb-ae40-8527-82c43a588a36"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Rho]", " ", 
   RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "u"}], " ", "\[Alpha]"}]]}], ")"}], " ", "x"}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "u"}], "+", 
      RowBox[{"r", " ", "x"}]}], ")"}], " ", 
    RowBox[{
     SuperscriptBox["V", "\[Prime]",
      MultilineFunction->None], "[", "x", "]"}]}], "+", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    SuperscriptBox["x", "2"], " ", 
    SuperscriptBox["\[Sigma]", "2"], " ", 
    RowBox[{
     SuperscriptBox["V", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "x", "]"}]}]}]}]], "Output",
 CellChangeTimes->{3.9907770295610714`*^9, 3.990777379789625*^9, 
  3.9907786332523556`*^9},
 CellLabel->"Out[99]=",ExpressionUUID->"022dcf31-1cdc-3342-b154-5469d9a817a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Take", " ", "the", " ", "derivative", " ", "with", " ", "respect", " ", 
    "to", " ", "u", " ", "to", " ", "find", " ", "the", " ", "First", " ", 
    "Order", " ", "Condition"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"foc", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"hjbExpression", ",", "u"}], "]"}], "==", "0"}]}], ";"}], "\n",
